# Normalize line endings to LF on checkin, leave working copy native
* text=auto eol=lf

# Explicitly declare text files
*.html   text
*.css    text
*.js     text
*.json   text
*.md     text
*.svg    text
*.xml    text
*.yml    text
*.yaml   text

# Binary files (don't touch)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.pdf    binary
*.mp4    binary
*.webm   binary
