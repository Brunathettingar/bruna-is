---
layout: layouts/page.njk
title: "Quote calculator"
bodyClass: "quoter-page"
description: "Get an online price estimate for fire sealing — choose opening type, wall type, fire rating and dimensions."
eleventyNavigation:
  key: quote-en
  order: 4
kicker: "Get an online price estimate — choose the opening type, wall type, fire rating and dimensions. We'll send the quote to your email instantly."
howItWorks:
  label: "How it works"
  heading: "An estimated price in three minutes."
  paragraphs:
    - "Add one row for each type of opening in your project. Choose the opening type, wall, fire rating and dimensions — the calculator computes an estimated price automatically."
  noticeStrong: "Note:"
  noticeBody: "This is an estimated price. The final price is confirmed with an on-site inspection. Prices exclude VAT."
cta:
  heading: "Need an on-site inspection? <span class=\"cta-band__highlight\">Let's talk.</span>"
  primaryHref: "#contact"
  primaryLabel: "Request an inspection"
  secondaryHref: "tel:+3548504405"
  secondaryLabel: "(+354) 850-4405"
---
<section class="page-hero">
  <img class="page-hero__image" src="/img/documentation.jpg" alt="" width="1600" height="900">
  <div class="scrim"></div>
  <div class="container">
    <h1>Quote calculator.</h1>
    <p class="kicker">{{ kicker }}</p>
  </div>
</section>

<section class="quoter-section">
  <div class="container">
    <div class="quoter-intro">
      <div>
        <div class="quoter-intro__label">{{ howItWorks.label }}</div>
        <h2>{{ howItWorks.heading }}</h2>
      </div>
      <div>
        {%- for p in howItWorks.paragraphs %}
        <p>{{ p }}</p>
        {%- endfor %}
        <div class="quoter-intro__notice">
          <strong>{{ howItWorks.noticeStrong }}</strong> {{ howItWorks.noticeBody }}
        </div>
      </div>
    </div>

    <form class="quoter" id="quoter" data-lang="{{ lang }}">
      <div class="quoter-header">
        <span>Opening type</span>
        <span>Wall type</span>
        <span>Fire rating</span>
        <span class="quoter-header__col--right">Width&nbsp;(cm)</span>
        <span class="quoter-header__col--right">Height&nbsp;(cm)</span>
        <span>From floor</span>
        <span class="quoter-header__col--right">Qty</span>
        <span class="quoter-header__col--right">Price</span>
        <span></span>
      </div>

      <div class="quoter-rows" id="quoter-rows"></div>

      <div class="quoter-actions">
        <button type="button" class="quoter-actions__add" data-quoter-add>+ Add a row</button>
      </div>

      <div class="quoter-total">
        <div>
          <div class="quoter-total__label">Estimated total</div>
          <div class="quoter-total__hint">Excl. VAT · estimated from your selections</div>
        </div>
        <div class="quoter-total__amount" id="total-amount">0 ISK</div>
      </div>

      <div class="quoter-customer">
        <h3>Send the estimated quote</h3>
        <div class="quoter-customer__grid">
          <input type="text" name="cust-name" placeholder="Name" required>
          <input type="text" name="cust-company" placeholder="Company / Project name">
          <input type="email" name="cust-email" placeholder="Email" required>
          <input type="tel" name="cust-phone" placeholder="Phone">
        </div>
        <textarea name="cust-notes" placeholder="Notes, project location, timeline…"></textarea>

        <div class="quoter-customer__submit-row">
          <span class="quoter-customer__note">You'll receive a confirmation by email and a project manager will call within 24 hours.</span>
          <button type="submit" class="quoter-customer__submit">
            <span>Send quote</span>
            <span class="quoter-customer__submit-arrow">→</span>
          </button>
        </div>

        <div class="quoter-confirm" id="quoter-confirm">
          {{ "quote.success" | i18n(lang) }}
        </div>
      </div>
    </form>
  </div>
</section>

{% include "partials/cta-band.njk" %}
