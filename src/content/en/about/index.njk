---
layout: layouts/page.njk
title: "About"
description: "Specialist fire-sealing and technical-insulation contractor serving owners and builders across Iceland since 2011."
bodyClass: about-page
eleventyNavigation:
  key: about-en
  order: 5
kicker: "A specialist fire-sealing and technical-insulation contractor serving Iceland since 2011."
story:
  label: "Our story"
  heading: "Founded to <span class=\"ul\">seal correctly</span> — and document it."
  paragraphs:
    - "Brunaþéttingar was founded in 2011 by four fire-sealing tradesmen who saw the gap between how the work was done and how it should be done."
    - "Today the company runs ~150 projects a year, from single-flat retrofits to the largest hospitals in the country, with a small permanent crew and a documentation system that ties every seal back to a drawing and a certification."
    - "We don't do fire engineering — we install what fire engineers spec, and we report it back end-to-end."
  signatureQuote: "&quot;Every seal goes on a drawing. Every drawing goes in the report. That's the whole company.&quot;"
  signatureAttribution: "— Founder, Brunaþéttingar ehf."
  timelineHeading: "Timeline"
philosophy:
  label: "Our principles"
  heading: "Six guiding lights for every project."
  lead: "These are the rules we follow, regardless of project size or schedule pressure."
team:
  label: "The team"
  heading: "A small team that knows every project."
  extraTile:
    initials: "+15"
    name: "15 more staff"
    role: "Fire-sealing installers"
    bio: "Crews based across the country."
cta:
  heading: "Ready to start your project? <span class=\"ul\">Get in touch.</span>"
  primaryHref: "/en/verdreiknir/"
  primaryLabel: "Get a quote"
  secondaryHref: "#contact"
  secondaryLabel: "Send a message"
---
{%- set milestones = collections['milestones-' + lang] | sort(false, false, 'data.year') %}
{%- set principles = collections['principles-' + lang] | sort(false, false, 'data.order') %}
{%- set teamMembers = collections['team-' + lang] | sort(false, false, 'data.order') %}

<section class="page-hero">
  <img class="page-hero__image" src="/img/iceland_hellisheidi.jpg" alt="" width="1600" height="900">
  <div class="scrim"></div>
  <div class="container">
    <h1>Um Brunaþéttingar.</h1>
    <p class="kicker">{{ kicker | safe }}</p>
  </div>
</section>

<section class="story">
  <div class="container">
    <div class="story__row">
      <div class="story__copy">
        <div class="story__label">{{ story.label }}</div>
        <h2>{{ story.heading | safe }}</h2>
        {%- for p in story.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
        <div class="story__signature">
          {{ story.signatureQuote | safe }}
          <small class="story__signature-meta">{{ story.signatureAttribution }}</small>
        </div>
      </div>
      <div class="story__timeline">
        <h4 class="story__timeline-title">{{ story.timelineHeading }}</h4>
        {%- for m in milestones %}
        <div class="story__timeline-row">
          <div class="story__timeline-year">{{ m.data.year }}</div>
          <div class="story__timeline-event">{{ m.data.event | safe }}</div>
        </div>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>

<section class="philosophy" id="stefna">
  <div class="container">
    <div class="philosophy__head">
      <div class="philosophy__label">{{ philosophy.label }}</div>
      <h2 class="philosophy__title">{{ philosophy.heading | safe }}</h2>
      <p class="philosophy__lead">{{ philosophy.lead | safe }}</p>
    </div>
    <div class="principles">
      {%- for p in principles %}
      <div class="principle">
        <span class="principle__num">{{ p.data.number }}</span>
        <h3>{{ p.data.title | safe }}</h3>
        <p>{{ p.data.description | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="team">
  <div class="container">
    <div class="team__head">
      <div class="team__label">{{ team.label }}</div>
      <h2 class="team__title">{{ team.heading | safe }}</h2>
    </div>
    <div class="team-grid">
      {%- for member in teamMembers %}
      <div class="team-card">
        <div class="team-card__avatar{% if member.data.avatar == 'orange' %} team-card__avatar--orange{% endif %}">{{ member.data.initials }}</div>
        <div class="team-card__body">
          <h4>{{ member.data.name }}</h4>
          <div class="team-card__role">{{ member.data.role }}</div>
          <div class="team-card__meta">{{ member.data.bio | safe }}</div>
        </div>
      </div>
      {%- endfor %}
      <div class="team-card">
        <div class="team-card__avatar team-card__avatar--orange">{{ team.extraTile.initials }}</div>
        <div class="team-card__body">
          <h4>{{ team.extraTile.name }}</h4>
          <div class="team-card__role">{{ team.extraTile.role }}</div>
          <div class="team-card__meta">{{ team.extraTile.bio | safe }}</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% include "partials/cta-band.njk" %}
