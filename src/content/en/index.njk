{%- set pillars = collections['featuredServices' + (lang == 'is' and 'Is' or 'En')] %}

<section class="hero">
  <img class="hero__image" src="/img/iceland_svartsengi.jpg" alt="" width="1600" height="900" loading="eager" fetchpriority="high">
  <div class="hero__scrim"></div>
  <div class="hero__container container">
    <h1>
      {{ heroHeading | safe }}
      <span class="hero__accent-bar"></span>
    </h1>
  </div>
</section>

<section class="statement">
  <div class="container">
    <div class="statement__row">
      <div>
        <h2>{{ statement.heading | safe }}</h2>
        <p class="statement__lead">{{ statement.lead | safe }}</p>
      </div>
      <a class="statement__cta" href="{{ statement.cta.href | locale_url }}">
        <span class="statement__cta-text">{{ statement.cta.text }}<span class="statement__cta-arrow" aria-hidden="true">→</span></span>
        <span class="statement__cta-caption">{{ statement.cta.caption }}</span>
      </a>
    </div>
  </div>
</section>

<section class="explainer">
  <div class="container">
    <div class="explainer__row">
      <div>
        <h3>{{ explainer.left.heading }}</h3>
        {%- for p in explainer.left.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
        <div class="explainer__chips">
          {%- for c in explainer.left.chips %}
          <span class="explainer__chip{% if c.style == 'blue' %} explainer__chip--blue{% endif %}">{{ c.label }}</span>
          {%- endfor %}
        </div>
      </div>
      <div>
        <h3>{{ explainer.right.heading }}</h3>
        {%- for p in explainer.right.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
        <div class="explainer__chips">
          {%- for c in explainer.right.chips %}
          <span class="explainer__chip{% if c.style == 'blue' %} explainer__chip--blue{% endif %}">{{ c.label }}</span>
          {%- endfor %}
        </div>
        <p>{{ explainer.right.footer | safe }}</p>
      </div>
    </div>
  </div>
</section>

<section class="pillars">
  <div class="container">
    <div class="pillar-grid">
      {%- for s in pillars %}
      <a class="pillar" href="{{ s.url }}">
        <div class="pillar__media{% if s.data.imageContain %} pillar__media--contain{% endif %}">
          <img class="pillar__image{% if s.data.imageContain %} pillar__image--contain{% endif %}" src="{{ s.data.image }}" alt="" width="1200" height="800">
          <div class="pillar__ico">{% include "partials/icons/" + s.data.icon + ".njk" %}</div>
        </div>
        <div class="pillar__body">
          <h3>{{ s.data.title | safe }}</h3>
          <p>{{ s.data.summary | safe }}</p>
          <ul>
            {%- for b in s.data.bullets %}
            {%- if loop.index <= 4 %}
            <li class="pillar__bullet">{{ b | safe }}</li>
            {%- endif %}
            {%- endfor %}
          </ul>
          <span class="pillar__more">{{ "ui.view_services" | i18n(lang) }} →</span>
        </div>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="process">
  <div class="container">
    <div class="process__head">
      <div class="process__label">{{ process.label }}</div>
      <h2 class="process__title">{{ process.heading | safe }}</h2>
    </div>
    <div class="process-grid">
      {%- for step in process.steps %}
      <div class="process-step">
        <div class="process-step__num">{{ step.num }}</div>
        <h4>{{ step.heading }}</h4>
        <p>{{ step.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="leading">
  <div class="container">
    <div class="leading__row">
      <div class="copy">
        <div class="leading__label">{{ leading.label }}</div>
        <h2>{{ leading.heading | safe }}</h2>
        {%- for p in leading.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
        <div class="leading__stats">
          {%- for s in leading.stats %}
          <div class="stat"><div class="leading__stat-num">{{ s.num }}</div><div class="leading__stat-label">{{ s.lbl }}</div></div>
          {%- endfor %}
        </div>
      </div>
      <div class="leading__media">
        <img class="leading__image" src="{{ leading.image }}" alt="" width="1200" height="900">
        <div class="leading__badge">
          <strong class="leading__badge-emphasis">{{ leading.badgeStrong }}</strong>
          {{ leading.badgeBody | safe }}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="sectors">
  <div class="container">
    <div class="sectors__head">
      <div class="sectors__label">{{ sectorsCallout.label }}</div>
      <h2 class="sectors__title">{{ sectorsCallout.heading | safe }}</h2>
    </div>
    <div class="sectors-grid">
      {%- for s in sectorsCallout.items %}
      <div class="sector">
        <div class="sector__ico">{% include "partials/icons/" + s.icon + ".njk" %}</div>
        <h4>{{ s.heading }}</h4>
        <p>{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="customers">
  <div class="container">
    <div class="customers__label">{{ customers.label }}</div>
    <div class="customers-row">
      {%- for p in partners %}
      <div class="customer-logo{% if p.style == 'sans' %} customer-logo--sans{% endif %}">{{ p.name }}</div>
      {%- endfor %}
    </div>
  </div>
</section>

{% include "partials/cta-band.njk" %}
