{# `services-<lang>` is a tag-based collection. Directory data tags every file
   in src/content/<lang>/thjonusta/ with that tag, including this index.njk —
   the `if s.url != page.url` guard inside the loop drops it. #}
{%- set services = collections['services-' + lang] | sort(false, false, 'data.order') %}
<section class="page-hero">
  <img class="page-hero__image" src="{{ heroImage }}" alt="" width="1600" height="900">
  <div class="page-hero__scrim"></div>
  <div class="container">
    <h1>{{ title }}</h1>
    <p class="page-hero__kicker">{{ kicker | safe }}</p>
  </div>
</section>

<section class="services-page__content">
  <div class="container">
    <div class="services-intro">
      <div>
        <div class="services-intro__label">{{ intro.label }}</div>
        <h2>{{ intro.heading | safe }}</h2>
      </div>
      <div>
        {%- for p in intro.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
      </div>
    </div>

    {%- for s in services %}
    {%- if s.url != page.url %}
    <article class="service-feature{% if loop.index0 % 2 == 1 %} service-feature--flipped{% endif %}">
      <div class="service-feature__media{% if s.data.imageContain %} service-feature__media--contain{% endif %}">
        <img class="service-feature__media-img" src="{{ s.data.image }}" alt="" width="1200" height="900">
      </div>
      <div class="service-feature__copy">
        <span class="service-feature__num">{{ s.data.number }} / {{ s.data.category }}</span>
        <h2><a href="{{ s.url }}">{{ s.data.title | safe }}</a></h2>
        <p class="service-feature__lead">{{ s.data.summary | safe }}</p>
        <div class="service-feature__insight">
          <strong>{{ s.data.insightStrong }}</strong>
          {{ s.data.insight | safe }}
        </div>
        <ul class="service-feature__bullets">
          {%- for b in s.data.bullets %}
          <li class="service-feature__bullet">{{ b | safe }}</li>
          {%- endfor %}
        </ul>
      </div>
    </article>
    {%- endif %}
    {%- endfor %}
  </div>
</section>

<section class="value-band">
  <div class="container">
    <div class="row">
      <div>
        <div class="label">{{ valueBand.label }}</div>
        <h2>{{ valueBand.heading | safe }}</h2>
      </div>
      <div>
        {%- for p in valueBand.paragraphs %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>

<section class="cta-band">
  <div class="container">
    <div class="row">
      <h2>{{ cta.heading | safe }}</h2>
      <div class="actions">
        <a class="btn primary" href="{{ cta.primaryHref }}"><span>{{ cta.primaryLabel }}</span> <span class="arrow">→</span></a>
        <a class="btn ghost" href="{{ cta.secondaryHref }}"><span>{{ cta.secondaryLabel }}</span> <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>
