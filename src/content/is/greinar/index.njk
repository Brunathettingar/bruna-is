{# `articles-<lang>` is a tag-based collection. Directory data tags every file
   in src/content/<lang>/greinar/ with that tag, including this index.njk —
   so without an explicit url filter the listing renders a phantom card
   pointing back at itself. The `if article.url != page.url` guard inside
   each loop drops it. #}
{%- set articles = collections['articles-' + lang] | sort(false, true, 'data.date') %}
{%- set featured = collections['featuredArticle' + (lang == 'is' and 'Is' or 'En')] | first %}
{%- set rest = articles | rejectattr('data.featured') %}

<section class="page-hero">
  <img class="page-hero__image" src="{{ heroImage }}" alt="" width="1600" height="900">
  <div class="page-hero__scrim"></div>
  <div class="container">
    <h1>{{ title }}</h1>
    <p class="page-hero__kicker">{{ kicker | safe }}</p>
  </div>
</section>

<section class="articles">
  <div class="container">
    {%- if featured %}
    <a class="article-featured" href="{{ featured.url }}">
      <div class="article-featured__media">
        <img class="article-featured__media-img" src="{{ featured.data.image }}" alt="" width="1600" height="900">
      </div>
      <div class="article-featured__body">
        <div class="article-featured__tag">
          <span class="article-featured__tag-pill">{{ "articles.featured" | i18n(lang) }}</span>
          {{ featured.data.category }}
        </div>
        <h2>{{ featured.data.title | safe }}</h2>
        <p>{{ featured.data.summary | safe }}</p>
        <div class="article-featured__meta">
          <span>{{ featured.data.date | dateDisplay(lang) }}</span>
          <span><strong>{{ featured.data.readTimeMinutes }} {{ "articles.read_time_minutes" | i18n(lang) }}</strong></span>
          <span>{{ featured.data.author }}</span>
        </div>
      </div>
    </a>
    {%- endif %}

    <div class="article-grid">
      {%- for article in rest %}
      {%- if article.url != page.url %}
      <a class="article-card" href="{{ article.url }}">
        <div class="article-card__media">
          <img class="article-card__media-img" src="{{ article.data.image }}" alt="" width="1200" height="900">
          <span class="article-card__tag">{{ article.data.category }}</span>
        </div>
        <div class="article-card__body">
          <h3>{{ article.data.title | safe }}</h3>
          <p>{{ article.data.summary | safe }}</p>
          <div class="article-card__meta">
            <span>{{ article.data.date | dateDisplay(lang) }}</span>
            <span>{{ article.data.readTimeMinutes }} {{ "articles.read_time_minutes" | i18n(lang) }}</span>
          </div>
        </div>
      </a>
      {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="cta-band">
  <div class="container">
    <div class="row">
      <h2>{{ cta.heading | safe }}</h2>
      <div class="actions">
        <a class="btn primary" href="{{ cta.primaryHref }}"><span>{{ cta.primaryLabel }}</span> <span class="arrow">→</span></a>
        <a class="btn ghost" href="{{ cta.secondaryHref }}"><span>{{ cta.secondaryLabel }}</span> <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>
