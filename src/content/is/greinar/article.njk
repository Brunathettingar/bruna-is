---
layout: layouts/page.njk
pagination:
  data: articles
  size: 1
  alias: article
permalink: "/greinar/{{ article.slug }}/"
eleventyComputed:
  title: "{{ article.title.is }}"
  description: "{{ article.summary.is }}"
  ogImage: "{{ article.image }}"
ogType: "article"
---
<section class="page-hero page-hero--article">
  <div class="bg" style="background-image: url('{{ article.image }}');"></div>
  <div class="scrim"></div>
  <div class="container">
    <div class="crumbs"><a href="/">Heim</a> &nbsp;/&nbsp; <a href="/greinar/">Greinar</a> &nbsp;/&nbsp; <span>{{ article.category[lang] }}</span></div>
    <h1>{{ article.title[lang] }}</h1>
    <p class="kicker">{{ article.summary[lang] }}</p>
  </div>
</section>

<section class="article-body">
  <div class="container">
    <div class="content-prose">
      <div class="article-meta">
        <span>{{ article.date | dateDisplay(lang) }}</span>
        <span>{{ article.readTimeMinutes }} mín lestur</span>
        <span>{{ article.author }}</span>
      </div>
      <p><em>[TBD — íslensk grein í vinnslu.]</em></p>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ article.title[lang] | jsonEscape }}",
  "description": "{{ article.summary[lang] | jsonEscape }}",
  "datePublished": "{{ article.date | dateIso }}",
  "author": { "@type": "Person", "name": "{{ article.author | jsonEscape }}" },
  "publisher": { "@type": "Organization", "name": "{{ meta.byLocale[lang].title | jsonEscape }}" },
  "image": "{{ meta.url }}{{ article.image }}",
  "inLanguage": "{{ lang }}"
}
</script>

<section class="cta-band">
  <div class="container">
    <div class="row">
      <h2>Tilbúin að hefja verkefnið? <span class="ul">Hafðu samband.</span></h2>
      <div class="actions">
        <a class="btn primary" href="/verdreiknir/"><span>Fá verðmat</span> <span class="arrow">→</span></a>
        <a class="btn ghost" href="/greinar/"><span>Fleiri greinar</span> <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>
