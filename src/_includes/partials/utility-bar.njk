{%- set alternates = page.url | locale_links %}
<div class="utility">
  <div class="container">
    <div class="row">
      <div class="left">
        <span class="pill">{{ "ui.certified" | i18n(lang) }}</span>
        <span>{{ "utility.tagline" | i18n(lang) }}</span>
      </div>
      <div class="right">
        <a href="tel:{{ meta.contact.phone.e164 }}">{{ meta.contact.phone.display }}</a>
        <a href="mailto:{{ meta.contact.email }}">{{ meta.contact.email }}</a>
        <span class="lang">
          {%- for link in alternates %}
          <a href="{{ link.url }}" lang="{{ link.lang }}" hreflang="{{ link.lang }}">{{ ("lang.label." + link.lang) | i18n(lang) }}</a>
          {%- endfor %}
          <a href="{{ page.url }}" class="active" lang="{{ lang }}">{{ ("lang.label." + lang) | i18n(lang) }}</a>
        </span>
      </div>
    </div>
  </div>
</div>
