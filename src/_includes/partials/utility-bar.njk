{%- set otherLang = lang == "is" and "en" or "is" %}
<div class="utility">
  <div class="container">
    <div class="row">
      <div class="left">
        <span class="pill">{{ "ui.certified" | t }}</span>
        <span>{{ "utility.tagline" | t }}</span>
      </div>
      <div class="right">
        <a href="tel:+3548504405">(+354) 850-4405</a>
        <a href="mailto:bruna@bruna.is">bruna@bruna.is</a>
        <span class="lang">
          <a href="{{ page.url | alternateUrl(lang) }}" lang="{{ otherLang }}" hreflang="{{ otherLang }}">{{ otherLang | upper }}</a>
          <a href="{{ page.url }}" class="active" lang="{{ lang }}">{{ lang | upper }}</a>
        </span>
      </div>
    </div>
  </div>
</div>
