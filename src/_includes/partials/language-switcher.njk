{%- set alternates = page.url | locale_links %}
<nav class="lang-switch" aria-label="{{ 'ui.language_switch' | t }}">
  <ul class="lang-switch__list" role="list">
    <li class="lang-switch__item">
      <a href="{{ page.url }}" aria-current="page" lang="{{ lang }}" hreflang="{{ lang }}" class="lang-switch__link lang-switch__link--current">{{ lang | upper }}</a>
    </li>
    {%- for link in alternates %}
    <li class="lang-switch__item">
      <a href="{{ link.url }}" lang="{{ link.lang }}" hreflang="{{ link.lang }}" class="lang-switch__link">{{ link.lang | upper }}</a>
    </li>
    {%- endfor %}
  </ul>
</nav>
