{%- set navCollection = lang == 'is' and collections.navIs or collections.navEn %}
<svg class="svg-defs" width="0" height="0" aria-hidden="true">
  <defs>
    <symbol id="logo-wordmark" viewBox="0 0 360 60">
      <text x="0" y="46" class="bruna" fill="#ee7c1d">BRUNA</text>
      <text x="170" y="46" class="pett" fill="#1453a8">þéttingar</text>
    </symbol>
  </defs>
</svg>

<header class="site-header">
  <div class="container">
    <div class="row">
      <a href="{{ '/' | locale_url }}" class="brand">
        <svg class="logo" viewBox="0 0 360 60" aria-label="{{ meta.byLocale[lang].title }}"><use href="#logo-wordmark"/></svg>
        <small class="tag">{{ "brand.tagline" | t | safe }}</small>
      </a>
      <button class="site-header__toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="{{ 'ui.menu' | t }}">
        <span></span><span></span><span></span>
      </button>
      <nav id="primary-nav" class="primary" aria-label="Main">
        <ul>
          {%- for entry in navCollection %}
          <li><a href="{{ entry.url }}"{% if entry.url == page.url %} class="active" aria-current="page"{% endif %}>{{ entry.data.title }}</a></li>
          {%- endfor %}
          <li><a href="#contact" class="cta">{{ "nav.contact" | t }}</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>
