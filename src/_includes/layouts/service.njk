---
layout: layouts/page.njk
eleventyComputed:
  ogImage: "{{ image }}"
ogType: "article"
---
<section class="page-hero">
  <img class="page-hero__image" src="{{ image }}" alt="" width="1600" height="900">
  <div class="page-hero__scrim"></div>
  <div class="container">
    <h1>{{ title | safe }}</h1>
    <p class="page-hero__kicker">{{ summary | safe }}</p>
  </div>
</section>

<section class="service-detail">
  <div class="container">
    <article class="service-feature">
      <div class="service-feature__media{% if imageContain %} service-feature__media--contain{% endif %}">
        <img class="service-feature__media-img" src="{{ image }}" alt="" width="1200" height="900">
      </div>
      <div class="service-feature__copy">
        <span class="service-feature__num">{{ number }} / {{ category }}</span>
        <h2>{{ title | safe }}</h2>
        <p class="service-feature__lead">{{ summary | safe }}</p>
        <div class="service-feature__insight">
          <strong>{{ insightStrong }}</strong>
          {{ insight | safe }}
        </div>
        <ul class="service-feature__bullets">
          {%- for b in bullets %}
          <li class="service-feature__bullet">{{ b | safe }}</li>
          {%- endfor %}
        </ul>
      </div>
    </article>

    <div class="content-prose">
      {{ content | safe }}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ title | jsonEscape }}",
  "description": "{{ summary | jsonEscape }}",
  "image": "{{ meta.url }}{{ image | jsonEscape }}",
  "provider": {
    "@type": "Organization",
    "name": "{{ meta.byLocale[lang].title | jsonEscape }}"
  },
  "inLanguage": "{{ lang }}"
}
</script>

{% include "partials/cta-band.njk" %}
